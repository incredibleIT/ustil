# USTIL 项目环境变量配置
# 复制此文件为 .env 并填入实际值

# ===========================================
# 数据库配置
# ===========================================
# MySQL root 密码
DB_PASSWORD=your_secure_database_password_here

# ===========================================
# JWT 配置
# ===========================================
# JWT 密钥（至少32个字符）
JWT_SECRET=YourProductionSecretKeyMustBeAtLeast32CharactersLongForSecurity

# ===========================================
# 应用配置（可选）
# ===========================================
# 后端端口（默认 8081）
SERVER_PORT=8081

# Spring Profile（默认 prod）
SPRING_PROFILES_ACTIVE=prod
